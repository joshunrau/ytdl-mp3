{
  "name": "ytdl-mp3",
  "version": "1.0.0",
  "description": "Easily Download YouTube Videos, Convert to MP3, and Apply Cover Art",
  "main": "./src/js/main.js",
  "scripts": {
    "browserify": "browserify ./src/main.js > ./src/bundle.js",
    "format-css": "find ./src -name '*.css' | xargs ./node_modules/.bin/css-beautify -r",
    "format-html": "find ./src -name '*.html' | xargs ./node_modules/.bin/html-beautify --r",
    "format-js": "find ./src -name '*.js' | xargs ./node_modules/.bin/js-beautify -r",
    "format": "npm run-script format-css && npm run-script format-html && npm run-script format-js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshunrau/ytdl-mp3.git"
  },
  "author": "Joshua Unrau",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/joshunrau/ytdl-mp3/issues"
  },
  "homepage": "https://github.com/joshunrau/ytdl-mp3#readme",
  "dependencies": {
    "browserify": "^17.0.0",
    "ffmpeg-static": "^4.4.1",
    "js-beautify": "^1.14.0",
    "node-id3": "^0.2.3",
    "ytdl-core": "^4.10.1"
  }
}
